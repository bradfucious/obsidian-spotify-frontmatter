{
  "name": "obsidian-spotify-frontmatter",
  "version": "1.0.0",
  "description": "A CLI utility that fetches Spotify metadata and inserts non-destructive YAML frontmatter into Obsidian notes.",
  "type": "module",
  "main": "spotify-frontmatter-cli.mjs",
  "scripts": {
    "start": "node spotify-frontmatter-cli.mjs",
    "lint": "eslint . --ext .js,.mjs,.ts --max-warnings=0",
    "test": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.1",
    "node-fetch": "^2.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "obsidian",
    "spotify",
    "frontmatter",
    "yaml",
    "cli",
    "metadata"
  ],
  "author": "Brad",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-filenames": "^1.3.2",
    "globals": "^17.4.0",
    "vitest": "^4.1.0"
  }
}
